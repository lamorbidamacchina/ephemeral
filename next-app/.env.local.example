# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=ephemeral_dev

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=

# SMTP (tested with Mailjet, works with any SMTP provider)
SMTP_FROM=you@example.com
SMTP_HOST=in-v3.mailjet.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Rate limiting — client IP source for per-IP auth limits.
# Behind a proxy/CDN, set this to the header your edge populates with the REAL
# client IP (and that clients can't forge):
#   Cloudflare → CF-Connecting-IP   |   raw Fly.io → Fly-Client-IP   |   nginx → X-Real-IP
# Leave unset for local/dev (falls back to X-Forwarded-For). Do NOT point it at a
# header that carries the proxy's own IP (e.g. Fly-Client-IP when Cloudflare is in
# front) — that would make every user share one IP and throttle everyone together.
# TRUSTED_IP_HEADER=CF-Connecting-IP
#
# Escape hatch: set to "true" to disable per-IP rate limiting entirely if a proxy
# misconfiguration ever collapses all users onto one IP. Per-account lockout and
# per-user limits stay active.
# DISABLE_IP_RATE_LIMIT=false

# Shown in emails and the UI
NEXT_PUBLIC_OWNER_NAME="Your Name"
NEXT_PUBLIC_CONTACT_EMAIL=you@example.com

# Web Push — public VAPID key (safe to expose). Generate a pair with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# Put the public key here and the private key in ws-server/.env
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
