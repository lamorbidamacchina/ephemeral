# Copy to fly.toml and fill in your values.
# Create the app first: fly apps create <name> --region fra
app = "your-app-name"
primary_region = "fra"

[build]

[build.args]
  # Baked into the client bundle at build time — update to match your actual app URLs
  NEXT_PUBLIC_APP_URL       = "https://your-app-name.fly.dev"
  NEXT_PUBLIC_WS_URL        = "https://your-ws-app-name.fly.dev"
  NEXT_PUBLIC_OWNER_NAME    = "Your Name"
  NEXT_PUBLIC_CONTACT_EMAIL = "you@example.com"

[http_service]
  internal_port = 3000
  force_https   = true
  auto_stop_machines  = "stop"
  auto_start_machines = true
  min_machines_running = 0

[[vm]]
  memory   = "512mb"
  cpu_kind = "shared"
  cpus     = 1
