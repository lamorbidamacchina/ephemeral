# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=ephemeral_dev

# Auth — must match the JWT_SECRET in next-app/.env.local
JWT_SECRET=

# WebSocket server port
WS_PORT=3001

# URL of the Next.js app (used for CORS)
NEXT_APP_URL=http://localhost:3000

# Web Push (VAPID). Generate a pair with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# The public key must match NEXT_PUBLIC_VAPID_PUBLIC_KEY in next-app/.env.local
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
